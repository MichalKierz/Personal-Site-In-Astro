---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = "Michał Kierzkowski",
  description = "Personal creative website.",
  pageClass = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
  </head>

  <body>
    <canvas id="site-background" aria-hidden="true" transition:persist></canvas>

    <Navigation />

    <main class:list={["page", pageClass]}>
      <slot />
    </main>

    <script>
      import "../styles/background.js";
    </script>
  </body>
</html>
