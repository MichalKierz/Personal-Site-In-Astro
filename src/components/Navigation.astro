---
import navigationContent from "../content/navigation.json";

type NavigationTab = {
  label: string;
  path: string;
  subdomain?: string;
};

const tabs = navigationContent.tabs as NavigationTab[];

const productionDomain = "michalkierzkowski.com";
const localPort = Astro.url.port ? `:${Astro.url.port}` : ":4321";

function normalizePath(path: string) {
  if (!path.startsWith("/")) {
    return `/${path}`;
  }

  return path;
}

function withTrailingSlash(path: string) {
  const normalizedPath = normalizePath(path);

  if (normalizedPath === "/") {
    return "/";
  }

  return normalizedPath.endsWith("/") ? normalizedPath : `${normalizedPath}/`;
}

function getHostname() {
  return Astro.url.hostname;
}

function isLocalHost() {
  const hostname = getHostname();

  return hostname === "localhost" || hostname.endsWith(".localhost");
}

function getCurrentSubdomain() {
  const hostname = getHostname();

  if (hostname.endsWith(".localhost")) {
    return hostname.replace(".localhost", "");
  }

  if (hostname.endsWith(`.${productionDomain}`)) {
    return hostname.replace(`.${productionDomain}`, "");
  }

  return "";
}

function getSectionFromPath(path: string) {
  const normalizedPath = normalizePath(path);

  if (normalizedPath === "/") {
    return "main";
  }

  return normalizedPath.split("/").filter(Boolean)[0] ?? "main";
}

function getCurrentSection() {
  const subdomain = getCurrentSubdomain();

  if (subdomain && subdomain !== "www") {
    return subdomain;
  }

  return getSectionFromPath(Astro.url.pathname);
}

function getTabSection(tab: NavigationTab) {
  const subdomain = tab.subdomain?.trim();

  if (subdomain) {
    return subdomain;
  }

  return getSectionFromPath(tab.path);
}

function getMainHref() {
  if (import.meta.env.DEV || isLocalHost()) {
    return `http://localhost${localPort}/`;
  }

  return `https://${productionDomain}/`;
}

function getTabHref(tab: NavigationTab) {
  const subdomain = tab.subdomain?.trim();
  const path = withTrailingSlash(tab.path);

  if (!subdomain) {
    if (import.meta.env.DEV || isLocalHost()) {
      return `http://localhost${localPort}${path}`;
    }

    return `https://${productionDomain}${path}`;
  }

  if (import.meta.env.DEV || isLocalHost()) {
    return `http://${subdomain}.localhost${localPort}/`;
  }

  return `https://${subdomain}.${productionDomain}/`;
}

const currentSection = getCurrentSection();
---

<header class="site-header">
  <div class="topbar">
    <a href={getMainHref()} class="logo"> Michał Kierzkowski </a>

    <nav class="nav" aria-label="Main navigation">
      {
        tabs.map((tab) => {
          const tabSection = getTabSection(tab);

          return (
            <a
              href={getTabHref(tab)}
              class:list={[
                "nav-link",
                { active: currentSection === tabSection },
              ]}
            >
              {tab.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
